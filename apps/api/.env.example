# Server
PORT=3000
ENV=development

# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/filora?sslmode=disable

# Clerk (web auth & sessions) - https://clerk.com
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SIGNING_SECRET=

# CLI sessions (opaque terminal tokens issued by the API)
# Optional: prefix/expiry tuning for issued CLI tokens
CLI_TOKEN_TTL_HOURS=720

# Storage Providers
# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
