# Base URL for the Filora API. Requests go through Vite's dev proxy by default.
VITE_API_BASE_URL=/api/v1

# Where the Vite dev server proxies /api to (the Go backend).
VITE_API_PROXY_TARGET=http://localhost:8080

# Clerk publishable key — owns web sign-in. Get it from the Clerk dashboard.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
